# ─── Modo PostgreSQL local (sin Docker) ───
# Requiere PostgreSQL instalado localmente y la DB creada.
# Script único: npm run db:local:setup  (generate + db push + seed)
# Arranque:       npm run dev:local
DATABASE_URL="postgresql://postgres:1234@localhost:5432/si_learning_red?schema=public"

# ─── Modo SQLite (sin Docker, zero-config) ───
# DATABASE_URL="file:./dev.db"

# ─── Modo PostgreSQL con Docker (npm run dev:pg) ───
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/si_learning_red?schema=public"

JWT_SECRET="change-this-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-this-to-another-secure-random-string"
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
